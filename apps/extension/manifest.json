{
  "manifest_version": 3,
  "name": "Iron Gate — AI Data Governance",
  "version": "0.2.7",
  "description": "Protect sensitive data in AI prompts. Real-time PII scanning and compliance for ChatGPT, Claude, Gemini, and more.",
  "homepage_url": "https://irongate-dashboard.vercel.app",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "webRequest",
    "alarms",
    "scripting",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://irongate-api.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "optional_host_permissions": [
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://poe.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://*.perplexity.ai/*",
    "https://you.com/*",
    "https://huggingface.co/chat/*",
    "https://groq.com/*"
  ],
  "background": {
    "service_worker": "src/worker/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://you.com/*",
        "https://huggingface.co/chat/*",
        "https://groq.com/*"
      ],
      "js": ["src/content/main-world.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://you.com/*",
        "https://huggingface.co/chat/*",
        "https://groq.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "storage": {
    "managed_schema": "managed_schema.json"
  },
  "web_accessible_resources": [
    {
      "resources": ["intelligence/model_weights.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src https://irongate-api.onrender.com http://localhost:3000 'self';"
  }
}
