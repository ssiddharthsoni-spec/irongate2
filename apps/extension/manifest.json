{
  "manifest_version": 3,
  "name": "Iron Gate — AI Data Protection",
  "version": "0.2.1",
  "description": "Detect and protect sensitive data in AI prompts. Real-time PII scanning, pseudonymization, and compliance monitoring for ChatGPT, Gemini, Claude, Copilot, and more.",
  "homepage_url": "https://irongate-dashboard.vercel.app",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "webRequest",
    "alarms",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://poe.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://*.perplexity.ai/*",
    "https://you.com/*",
    "https://huggingface.co/chat/*",
    "https://groq.com/*",
    "https://irongate-api.onrender.com/*"
  ],
  "background": {
    "service_worker": "src/worker/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://you.com/*",
        "https://huggingface.co/chat/*",
        "https://groq.com/*"
      ],
      "js": ["src/content/main-world.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://*.perplexity.ai/*",
        "https://you.com/*",
        "https://huggingface.co/chat/*",
        "https://groq.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
