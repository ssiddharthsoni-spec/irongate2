{
  "name": "@iron-gate/extension",
  "version": "0.2.7",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contracts": "vitest run tests/payload-contract.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:wire": "playwright test --config=playwright.wire.config.ts",
    "test:selector-health": "playwright test tests/e2e/selector-health.spec.ts --headed"
  },
  "dependencies": {
    "@iron-gate/config": "workspace:*",
    "@iron-gate/crypto": "workspace:*",
    "@iron-gate/types": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@playwright/test": "^1.58.2",
    "ws": "^8.18.0",
    "@types/chrome": "^0.0.300",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
