{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current Test File",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}"],
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug API Tests",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": ["run", "--config", "apps/api/vitest.config.ts"],
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Extension Tests",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": ["run", "--config", "apps/extension/vitest.config.ts"],
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Security Tests Only",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": [
        "run",
        "--config", "apps/api/vitest.config.ts",
        "tests/security-hardening.test.ts",
        "tests/rbac-enforcement.test.ts",
        "tests/compliance-audit.test.ts"
      ],
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Integration Tests",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/vitest/vitest.mjs",
      "args": [
        "run",
        "--config", "apps/api/vitest.config.ts",
        "tests/integration/"
      ],
      "smartStep": true,
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Iron Gate: Debug Comprehensive E2E",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/e2e/comprehensive-detection.spec.ts",
        "--headed",
        "--reporter=list"
      ],
      "cwd": "${workspaceRoot}/apps/extension",
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Iron Gate: Debug Wire Verification E2E",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "program": "${workspaceRoot}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/e2e/wire-verification.spec.ts",
        "--headed",
        "--reporter=list"
      ],
      "cwd": "${workspaceRoot}/apps/extension",
      "smartStep": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Iron Gate: Debug Drive Loop",
      "autoAttachChildProcesses": true,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceRoot}/apps/extension/tests/e2e/drive.ts",
      "args": ["full"],
      "cwd": "${workspaceRoot}/apps/extension",
      "smartStep": true,
      "console": "integratedTerminal"
    }
  ]
}
