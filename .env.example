# Iron Gate Environment Variables

# Database (Supabase pooler connection string)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Redis (optional — for distributed rate limiting; falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Authentication (Clerk)
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# ── Cloud LLM (Gemini is the default for Tier 3 classification + intent) ────
# Required for Tier 3 sensitivity classification and intent classification.
# Uses Google's OpenAI-compatible endpoint so no special SDK is needed.
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: pin a specific Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: alternative cloud LLM (legacy — Gemini takes precedence if both are set)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Override the classifier endpoint + model if needed
# CLASSIFIER_LLM_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# CLASSIFIER_LLM_API_KEY=
# CLASSIFIER_LLM_MODEL=gemini-2.5-flash

# API
API_URL=https://irongate-api.onrender.com
NEXT_PUBLIC_API_URL=https://irongate-api.onrender.com/v1

# Dashboard URL (for CORS allowlist in the API)
DASHBOARD_URL=https://irongate-dashboard.vercel.app

# Chrome Extension ID (from chrome://extensions after loading unpacked)
# Required for CORS — the API must allow requests from this origin
CHROME_EXTENSION_ID=your-extension-id-here

# ── Cryptographic Secrets ────────────────────────────────────────────────────
# PRODUCTION: Use separate secrets for encryption and signing (recommended).
# IRON_GATE_ENCRYPTION_SECRET — derives per-firm AES-256-GCM keys for pseudonym + webhook encryption
# IRON_GATE_SIGNING_SECRET    — derives HMAC-SHA256 key for audit trail signatures
# Splitting prevents a single secret compromise from affecting both encryption and signing.
IRON_GATE_ENCRYPTION_SECRET=generate-a-strong-random-secret-here
IRON_GATE_SIGNING_SECRET=generate-a-different-strong-random-secret-here
# Legacy fallback (used if the above are not set):
IRON_GATE_MASTER_SECRET=generate-a-strong-random-secret-here

# Detection Service (optional — Python gRPC service)
DETECTION_SERVICE_URL=http://localhost:8080

# Firm defaults (development)
DEFAULT_FIRM_ID=6a3de5b8-2ad3-4d94-9171-c02951e09e4e

# Sentry (optional — error tracking)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# Stripe (optional — billing; mock mode if not set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=

# Email (optional — console fallback if not set)
RESEND_API_KEY=

# Kill switch admin keys (required for emergency admin actions)
ADMIN_KEY_1=
ADMIN_KEY_2=

# Database connection pool tuning
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=20000

# Logging
LOG_LEVEL=info

# PostHog (optional — product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Environment
NODE_ENV=development

# ── Staging Environment ──────────────────────────────────────────────────────
# When deploying to staging, use a SEPARATE Supabase project and Clerk instance.
# STAGING_API_URL=https://irongate-api-staging.onrender.com
# STAGING_DASHBOARD_URL=https://irongate-dashboard-staging.vercel.app
# STAGING_DATABASE_URL=postgresql://postgres.<staging-ref>:<password>@aws-0-us-west-2.pooler.supabase.com:6543/postgres
